# FocusFlow API - copy to .env and fill in

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:shatashu@localhost:5432/focusflow

# Auth (use a long random string in production)
SECRET_KEY=change-me-in-production-use-env

# OpenAI (or OpenAI-compatible API)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://your-proxy/v1  # optional

# Optional overrides
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_MODEL=gpt-4o-mini
# UPLOAD_DIR=./uploads
